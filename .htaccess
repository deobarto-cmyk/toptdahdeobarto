Options -MultiViews
RewriteEngine On

# Redirect explicit /www/ URLs to root to keep URLs clean
RewriteCond %{THE_REQUEST} \s/www/(\S*)\s [NC]
RewriteRule ^ /%1 [R=301,L]

# Force HTTPS redirection (compatible avec le reverse-proxy Alwaysdata, exclut localhost)
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1|::1)$ [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Serve index.php at root by default
DirectoryIndex index.php

# 0. Redirect /index, /index.html and /index.php to root /
RewriteCond %{THE_REQUEST} \s/+index(\.html|\.php)?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# 1. Redirect direct access to /pages/xyz.php or /pages/xyz to clean /xyz URL
RewriteCond %{THE_REQUEST} \s/pages/(.+?)\.(php|html)[\s?] [NC]
RewriteRule ^pages/(.+?)\.(php|html)$ /$1 [R=301,L]

# Redirect requests with extension (.html or .php) directly at root to clean URL
RewriteCond %{THE_REQUEST} \s/+(.+?)\.(html|php)[\s?] [NC]
RewriteRule ^(.+?)\.(html|php)$ /$1 [R=301,L]

# 2. Internally rewrite clean URL to .php file in the pages/ directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{DOCUMENT_ROOT}/www/pages/$1.php -f [OR]
RewriteCond %{DOCUMENT_ROOT}/pages/$1.php -f
RewriteRule ^([^/]+)$ pages/$1.php [L]
